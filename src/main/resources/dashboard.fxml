<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.suka.controller.dashboardController">

    <Label fx:id="welcomeLabel" alignment="CENTER" layoutX="-7.0" layoutY="7.0" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: #1234;" text="DASHBOARD" />
   <Button fx:id="settingButton" alignment="CENTER" layoutX="432.0" layoutY="14.0" mnemonicParsing="false" onAction="#goToSetting" prefHeight="26.0" prefWidth="89.0" text="setting" textAlignment="JUSTIFY" />
   <Button fx:id="manager" layoutX="321.0" layoutY="14.0" mnemonicParsing="false" onAction="#goToManageUser" prefHeight="26.0" prefWidth="89.0" text="Manager" />
   <Button layoutX="455.0" layoutY="360.0" mnemonicParsing="false" onAction="#goToChat" prefHeight="26.0" prefWidth="89.0" text="Chat room" />

</AnchorPane>
