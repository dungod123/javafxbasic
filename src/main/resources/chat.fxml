<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500" prefWidth="772.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.suka.controller.ChatController">

    <!-- title -->

    <Label layoutX="20" layoutY="20" text="Realtime Chat" />

    <!-- current user -->

    <Label fx:id="usernameLabel" layoutX="450" layoutY="20" text="User" />

    <!-- message list -->

    <ListView fx:id="messageListView" layoutX="20" layoutY="60" prefHeight="340" prefWidth="560" />

    <!-- input -->

    <TextField fx:id="messageField" layoutX="20" layoutY="430" prefWidth="450" promptText="Type message..." />

    <!-- send -->

    <Button layoutX="490" layoutY="430" onAction="#handleSend" prefWidth="90" text="Send" />

    <!-- logout -->

    <Button layoutX="435.0" layoutY="466.0" onAction="#handleBackDashboard" prefHeight="26.0" prefWidth="148.0" text="Back to dashboard" />
   <ListView fx:id="onlineUsersListView" layoutX="603.0" layoutY="60.0" prefHeight="340.0" prefWidth="155.0" />
   <Label alignment="CENTER" layoutX="623.0" layoutY="38.0" prefHeight="18.0" prefWidth="86.0" text="Online:" textFill="#2dcd18" />
   <TextField fx:id="recipientField" layoutX="138.0" layoutY="25.0" promptText="recipient" />
   <TextField fx:id="searchField" layoutX="600.0" layoutY="430.0" promptText="search message" />
   <Button layoutX="636.0" layoutY="466.0" mnemonicParsing="false" onAction="#handleSearch" prefHeight="18.0" prefWidth="86.0" text="search" />

</AnchorPane>
